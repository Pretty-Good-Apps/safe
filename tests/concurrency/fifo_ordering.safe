-- Test: fifo_ordering
-- Description: Verifies FIFO ordering preservation in a channel.
--   A producer sends sequential values 0, 1, 2, ... and a consumer
--   verifies they arrive in the same order. FIFO ordering is a
--   normative requirement of Safe channels.
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.2.p20:8aa1a21e
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.3.p27:ef0ce6bd
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.3.p28:ea6bd13c
-- Expected: ACCEPT

package fIFO_Ordering

   type sequence_Number is range 0 to 999;

   channel Seq_Ch : sequence_Number capacity 8;

   --  Producer: sends 0, 1, 2, ..., 999, 0, 1, ... in order.
   task Producer
      n : sequence_Number = 0;

      loop
         send Seq_Ch, n;
         if n < 999
            n = n + 1;
         else
            n = 0;




   --  Consumer: receives values and verifies ordering.
   --  Each received value should equal the expected next sequence number.
   task Consumer
      expected : sequence_Number = 0;
      received : sequence_Number;

      loop
         receive Seq_Ch, received;
         --  FIFO guarantees Received = Expected.
         --  (In a real test harness, an assertion would verify this.)
         if expected < 999
            expected = expected + 1;
         else
            expected = 0;





