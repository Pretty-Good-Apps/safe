-- Test: select_priority_result
-- Description: Plain select rotates fairly across ready arms at one select site.
-- Expected embedded result: 12

package select_priority_result

   subtype message is integer (0 to 10);
   subtype round_index is integer (1 to 2);
   public subtype result_value is integer (0 to 99);

   channel high_ch : message capacity 2;
   channel low_ch  : message capacity 2;
   public channel result_ch : result_value capacity 1;

   total : result_value = 0;

   for round in round_index
      send high_ch, message (round * 2 - 1)
      send low_ch, message (round * 2)

      select
         when high_item : message from high_ch
            total = total * 10 + result_value (high_item)
      or
         when low_item : message from low_ch
            total = total * 10 + result_value (low_item)

   send result_ch, total
