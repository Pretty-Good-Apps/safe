-- Test: neg_pr117_casefold_collision
-- Description: Reference-signal naming rejects same-scope bindings that differ only by case.
-- Expected: REJECT source_frontend_error

package neg_PR117_Casefold_Collision

   type payload is record
      value : integer;

   type payload_Ptr is access payload;

   function demo returns integer
      Source : payload_Ptr = null;
      source : payload_Ptr = null;

      if Source == null and then source == null
         return 0;

      return 1;
