-- Test: rule4_linked_list_sum
-- Description: Linked-list prefix accumulation with null-guarded dereferences.
--   The sample performs arithmetic on both a visit count and node values
--   across a bounded prefix of a linked structure.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.4.p136:fa5e94b7
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.3.2.p96a:0eaf48aa
-- Expected: ACCEPT

package safe_Linked_List_Sum

   type node;
   type node_Ptr is access node;
   type visit_Count is range 0 to 3;
   type node_Value is range 0 to 100;
   type total_Value is range 0 to 300;

   type node is record
      value : node_Value;
      Next  : node_Ptr;


   function summarize_Prefix (Head : node_Ptr) returns total_Value
      count : visit_Count = 0;
      total : total_Value = 0;

      if Head != null
         count = count + 1;
         total = total + total_Value (Head.value);
         if count == 3
            return total_Value (total);


         if Head.Next != null
            var Second : access constant node = Head.Next.access;
            count = count + 1;
            total = total + total_Value (Second.value);
            if count == 3
               return total_Value (total);


            if Second.Next != null
               var Third : access constant node = Second.Next.access;
               count = count + 1;
               total = total + total_Value (Third.value);
               if count == 3
                  return total_Value (total);



      return total_Value (total);


