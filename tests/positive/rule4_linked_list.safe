-- Test: rule4_linked_list
-- Description: Linked list traversal with null guards.
--   Each dereference is preceded by a null check on the current node.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.4.p136:fa5e94b7
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.3.2.p96a:0eaf48aa
-- Expected: ACCEPT

package safe_Linked_List

   type node;
   type node_Ptr is access node;

   type node is record
      value : integer;
      Next  : node_Ptr;


   --  Last_Value: traverses to the tail and returns its value.
   --  The traversal uses a local observer derived from Head.Access.
   function last_Value (Head : node_Ptr) returns integer

      if Head == null
         return 0;

      var Current : access constant node = Head.access;
      while Current != null
         if Current.Next == null
            return Current.value;
         else
            Current = Current.Next.access;

      return 0;


   --  Has_Tail: proves nested null guards before traversing further.
   function has_Tail (Head : node_Ptr) returns boolean

      if Head == null
         return False;

      var Current : access constant node = Head.access;
      while Current != null
         if Current.Next == null
            return False;
         else if Current.Next.Next == null
            return True;
         else
            Current = Current.Next.access;

      return False;


