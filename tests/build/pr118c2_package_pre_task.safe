package pr118c2_package_pre_task

   subtype counter is integer (0 to 41);
   channel start_ch : counter capacity 1;

   task worker with priority = 10, sends start_ch, receives start_ch
      loop
         receive start_ch, start : counter
         print (start)
         send start_ch, start
         delay 0.05

   send start_ch, 41
